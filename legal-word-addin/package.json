{
  "name": "legal-word-addin",
  "version": "1.0.0",
  "private": true,
  "description": "Word task pane add-in for legal document assistance with configurable AI providers",
  "scripts": {
    "build": "webpack --mode production && node scripts/write-manifest.js",
    "manifest": "node scripts/write-manifest.js",
    "dev": "webpack serve --mode development",
    "server": "node server/proxy.mjs",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "presidio": "node server/run-presidio.mjs",
    "presidio:install": "node server/install-presidio.mjs",
    "sideload:mac": "bash scripts/sideload-mac-word.sh",
    "sideload:mac:reset": "bash scripts/sideload-mac-word.sh --clear-cache",
    "sideload:windows": "powershell -ExecutionPolicy Bypass -File scripts/sideload-windows.ps1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "html-webpack-plugin": "^5.6.3",
    "office-addin-dev-certs": "^1.13.5",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
